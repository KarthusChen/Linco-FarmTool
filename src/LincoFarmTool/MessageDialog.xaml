<Window x:Class="LincoFarmTool.MessageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="提示"
        Width="340" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" Topmost="True"
        FontFamily="Microsoft YaHei UI"
        TextOptions.TextFormattingMode="Ideal">

    <Border CornerRadius="18" Margin="12" Background="{StaticResource CardBg}"
            BorderBrush="{StaticResource Line}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="22" ShadowDepth="3" Opacity="0.28" Color="#7A6A4A"/>
        </Border.Effect>

        <StackPanel Margin="22,20,22,22">
            <TextBlock x:Name="TitleText" FontSize="16" FontWeight="Bold" Foreground="{StaticResource Ink}"/>
            <TextBlock x:Name="BodyText" Margin="0,10,0,0" FontSize="13" LineHeight="20"
                       Foreground="{StaticResource Muted}" TextWrapping="Wrap"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button x:Name="CancelBtn" Content="取消" Width="80" Style="{StaticResource GhostButton}" Click="OnCancel"/>
                <Button x:Name="OkBtn" Content="确定" Width="96" Margin="10,0,0,0"
                        Style="{StaticResource AccentButton}" Click="OnOk" IsDefault="True"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
