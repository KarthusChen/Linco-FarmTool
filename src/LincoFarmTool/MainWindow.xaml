<Window x:Class="LincoFarmTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Linco 收菜闹钟"
        Width="250" SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

    <Border CornerRadius="16" Margin="8" Padding="10"
            Background="#F5FFFDF5" BorderBrush="#FFDCC9A0" BorderThickness="2">
        <Border.Effect>
            <DropShadowEffect BlurRadius="14" ShadowDepth="2" Opacity="0.35" Color="#7A6A4A"/>
        </Border.Effect>

        <StackPanel>

            <!-- 桌宠：全宇宙最可爱的小老鼠 🐭（拖动手柄 / 整个面板） -->
            <Viewbox x:Name="PetBox" Width="126" Height="104" HorizontalAlignment="Center">
                <Viewbox.RenderTransform>
                    <TranslateTransform x:Name="PetShift" Y="0"/>
                </Viewbox.RenderTransform>
                <Canvas Width="200" Height="160">
                    <!-- 尾巴（画在最底层） -->
                    <Path Stroke="#FFE39BB4" StrokeThickness="6" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          Data="M 146,128 C 176,124 182,100 168,92 C 158,86 152,96 160,102"/>

                    <!-- 左耳 -->
                    <Ellipse Canvas.Left="46" Canvas.Top="34" Width="52" Height="52"
                             Fill="#FFCFC7DA" Stroke="#FF6B6478" StrokeThickness="3"/>
                    <Ellipse Canvas.Left="56" Canvas.Top="44" Width="32" Height="32" Fill="#FFF6C2D4"/>
                    <!-- 右耳 -->
                    <Ellipse Canvas.Left="102" Canvas.Top="34" Width="52" Height="52"
                             Fill="#FFCFC7DA" Stroke="#FF6B6478" StrokeThickness="3"/>
                    <Ellipse Canvas.Left="112" Canvas.Top="44" Width="32" Height="32" Fill="#FFF6C2D4"/>

                    <!-- 身体 / 头（圆滚滚一体） -->
                    <Ellipse Canvas.Left="52" Canvas.Top="52" Width="96" Height="94"
                             Fill="#FFDDD6E6" Stroke="#FF6B6478" StrokeThickness="3"/>
                    <!-- 浅色肚皮 -->
                    <Ellipse Canvas.Left="74" Canvas.Top="92" Width="52" Height="50" Fill="#FFF3EFF8"/>

                    <!-- 腮红 -->
                    <Ellipse Canvas.Left="66" Canvas.Top="98" Width="16" Height="10" Fill="#66F191AE"/>
                    <Ellipse Canvas.Left="118" Canvas.Top="98" Width="16" Height="10" Fill="#66F191AE"/>

                    <!-- 眼睛（大而亮） -->
                    <Ellipse Canvas.Left="80" Canvas.Top="78" Width="16" Height="19" Fill="#FF322C3A"/>
                    <Ellipse Canvas.Left="104" Canvas.Top="78" Width="16" Height="19" Fill="#FF322C3A"/>
                    <!-- 眼睛高光 -->
                    <Ellipse Canvas.Left="84" Canvas.Top="81" Width="6" Height="6" Fill="White"/>
                    <Ellipse Canvas.Left="108" Canvas.Top="81" Width="6" Height="6" Fill="White"/>

                    <!-- 鼻子 -->
                    <Ellipse Canvas.Left="93" Canvas.Top="100" Width="14" Height="10" Fill="#FFE87DA0"/>
                    <!-- 嘴 -->
                    <Path Stroke="#FF6B6478" StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          Data="M 100,110 C 100,116 94,118 90,115 M 100,110 C 100,116 106,118 110,115"/>

                    <!-- 胡须 -->
                    <Path Stroke="#FFA79FB6" StrokeThickness="1.6" StrokeStartLineCap="Round"
                          Data="M 92,104 L 60,98 M 92,108 L 58,110 M 108,104 L 140,98 M 108,108 L 142,110"/>

                    <!-- 小手 + 抱着的菜苗 🌱 -->
                    <Ellipse Canvas.Left="78" Canvas.Top="126" Width="20" Height="17"
                             Fill="#FFCFC7DA" Stroke="#FF6B6478" StrokeThickness="2.5"/>
                    <Ellipse Canvas.Left="102" Canvas.Top="126" Width="20" Height="17"
                             Fill="#FFCFC7DA" Stroke="#FF6B6478" StrokeThickness="2.5"/>
                    <Path Stroke="#FF5EA84F" StrokeThickness="4" StrokeStartLineCap="Round"
                          Data="M 100,132 L 100,120"/>
                    <Path Fill="#FF7FC66B" Stroke="#FF4F9E44" StrokeThickness="1.5"
                          Data="M 100,124 C 92,120 88,124 90,130 C 96,130 100,128 100,124 Z"/>
                    <Path Fill="#FF7FC66B" Stroke="#FF4F9E44" StrokeThickness="1.5"
                          Data="M 100,122 C 108,117 113,121 111,128 C 104,128 100,126 100,122 Z"/>
                </Canvas>
            </Viewbox>

            <!-- 标题栏 -->
            <Grid Margin="2,2,2,6">
                <TextBlock Text="🌾 收菜闹钟" FontWeight="Bold" FontSize="14"
                           Foreground="#FF5A4A2E" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="PlantBtn" Content="🌱 种菜" Height="26"
                            FontSize="12" FontWeight="Bold" Padding="6,0"
                            Foreground="#FFB5730A" Background="#FFFDEFC9" BorderBrush="#FFF0D9A8"
                            Cursor="Hand" Click="OnPlant" ToolTip="种菜：一键设肝帝闹钟"/>
                    <Button x:Name="AddBtn" Content="＋" Width="26" Height="26" Margin="6,0,0,0"
                            FontSize="16" FontWeight="Bold"
                            Foreground="#FF5A8A3A" Background="#FFEAF6DC" BorderBrush="#FFB9D89A"
                            Cursor="Hand" Click="OnAddTask" ToolTip="手动添加单个闹钟"/>
                </StackPanel>
            </Grid>

            <!-- 空状态提示 -->
            <TextBlock x:Name="EmptyHint" Text="还没有闹钟，点 ＋ 添加一个"
                       Foreground="#FFAA9B7A" FontSize="12" HorizontalAlignment="Center"
                       Margin="0,4,0,6"/>

            <!-- 闹钟列表 -->
            <ItemsControl x:Name="TaskList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,6" Padding="8,6" CornerRadius="10"
                                Background="#FFF3F7EC" BorderBrush="#FFDDE8C9" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="13"
                                               Foreground="#FF3E3A2E" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock FontSize="11" Foreground="#FF8A7B5A">
                                        <Run Text="{Binding CountdownText, Mode=OneWay}"/>
                                        <Run Text="  ·  "/>
                                        <Run Text="{Binding TargetText, Mode=OneWay}"/>
                                    </TextBlock>
                                </StackPanel>
                                <Button Grid.Column="1" Content="✕" Width="22" Height="22"
                                        VerticalAlignment="Top" FontSize="11"
                                        Foreground="#FFC26A6A" Background="Transparent"
                                        BorderThickness="0" Cursor="Hand"
                                        Click="OnDeleteTask" ToolTip="删除"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </Border>
</Window>
