<Window x:Class="LincoFarmTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Linco 收菜闹钟"
        Width="250" SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

    <Border CornerRadius="16" Margin="8" Padding="10"
            Background="#F5FFFDF5" BorderBrush="#FFDCC9A0" BorderThickness="2">
        <Border.Effect>
            <DropShadowEffect BlurRadius="14" ShadowDepth="2" Opacity="0.35" Color="#7A6A4A"/>
        </Border.Effect>

        <StackPanel>

            <!-- 桌宠猫（拖动手柄就是它 / 整个面板） -->
            <Viewbox x:Name="CatBox" Width="118" Height="96" HorizontalAlignment="Center">
                <Viewbox.RenderTransform>
                    <TranslateTransform x:Name="CatShift" Y="0"/>
                </Viewbox.RenderTransform>
                <Canvas Width="200" Height="160">
                    <!-- 身体 -->
                    <Ellipse Canvas.Left="55" Canvas.Top="55" Width="90" Height="80"
                             Fill="#FFF3E9D2" Stroke="#FF4A4036" StrokeThickness="3"/>
                    <!-- 耳朵 -->
                    <Polygon Points="78,40 92,18 104,42" Fill="#FFF3E9D2" Stroke="#FF4A4036" StrokeThickness="3"/>
                    <Polygon Points="96,42 108,18 122,40" Fill="#FFF3E9D2" Stroke="#FF4A4036" StrokeThickness="3"/>
                    <!-- 头 -->
                    <Ellipse Canvas.Left="70" Canvas.Top="35" Width="60" Height="55"
                             Fill="#FFF3E9D2" Stroke="#FF4A4036" StrokeThickness="3"/>
                    <!-- 眼睛 -->
                    <Ellipse x:Name="EyeL" Canvas.Left="86" Canvas.Top="55" Width="8" Height="8" Fill="#FF4A4036"/>
                    <Ellipse x:Name="EyeR" Canvas.Left="106" Canvas.Top="55" Width="8" Height="8" Fill="#FF4A4036"/>
                    <!-- 腮红 -->
                    <Ellipse Canvas.Left="80" Canvas.Top="65" Width="10" Height="6" Fill="#55E8836B"/>
                    <Ellipse Canvas.Left="110" Canvas.Top="65" Width="10" Height="6" Fill="#55E8836B"/>
                    <!-- 爪子（静止，抱在身前） -->
                    <Ellipse Canvas.Left="70" Canvas.Top="100" Width="26" Height="22"
                             Fill="#FFEFE0C4" Stroke="#FF4A4036" StrokeThickness="3"/>
                    <Ellipse Canvas.Left="104" Canvas.Top="100" Width="26" Height="22"
                             Fill="#FFEFE0C4" Stroke="#FF4A4036" StrokeThickness="3"/>
                </Canvas>
            </Viewbox>

            <!-- 标题栏 -->
            <Grid Margin="2,2,2,6">
                <TextBlock Text="🌾 收菜闹钟" FontWeight="Bold" FontSize="14"
                           Foreground="#FF5A4A2E" VerticalAlignment="Center"/>
                <Button x:Name="AddBtn" Content="＋" Width="26" Height="26"
                        HorizontalAlignment="Right" FontSize="16" FontWeight="Bold"
                        Foreground="#FF5A8A3A" Background="#FFEAF6DC" BorderBrush="#FFB9D89A"
                        Cursor="Hand" Click="OnAddTask" ToolTip="添加闹钟"/>
            </Grid>

            <!-- 空状态提示 -->
            <TextBlock x:Name="EmptyHint" Text="还没有闹钟，点 ＋ 添加一个"
                       Foreground="#FFAA9B7A" FontSize="12" HorizontalAlignment="Center"
                       Margin="0,4,0,6"/>

            <!-- 闹钟列表 -->
            <ItemsControl x:Name="TaskList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,6" Padding="8,6" CornerRadius="10"
                                Background="#FFF3F7EC" BorderBrush="#FFDDE8C9" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="13"
                                               Foreground="#FF3E3A2E" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock FontSize="11" Foreground="#FF8A7B5A">
                                        <Run Text="{Binding CountdownText, Mode=OneWay}"/>
                                        <Run Text="  ·  "/>
                                        <Run Text="{Binding TargetText, Mode=OneWay}"/>
                                    </TextBlock>
                                </StackPanel>
                                <Button Grid.Column="1" Content="✕" Width="22" Height="22"
                                        VerticalAlignment="Top" FontSize="11"
                                        Foreground="#FFC26A6A" Background="Transparent"
                                        BorderThickness="0" Cursor="Hand"
                                        Click="OnDeleteTask" ToolTip="删除"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </Border>
</Window>
