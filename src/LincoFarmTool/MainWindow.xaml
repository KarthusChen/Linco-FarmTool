<Window x:Class="LincoFarmTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Linco 桌宠"
        Width="220" Height="180"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

    <!-- Viewbox 让整只猫随窗口等比缩放 -->
    <Viewbox>
        <!-- 200x160 的画布坐标系 -->
        <Canvas Width="200" Height="160">

            <!-- “桌面”横线：爪子拍在上面 -->
            <Rectangle Canvas.Left="20" Canvas.Top="120" Width="160" Height="10"
                       RadiusX="5" RadiusY="5" Fill="#33000000"/>

            <!-- 身体 -->
            <Ellipse Canvas.Left="55" Canvas.Top="55" Width="90" Height="80"
                     Fill="#FFF3E9D2" Stroke="#FF4A4036" StrokeThickness="3"/>

            <!-- 耳朵 -->
            <Polygon Points="78,40 92,18 104,42" Fill="#FFF3E9D2" Stroke="#FF4A4036" StrokeThickness="3"/>
            <Polygon Points="96,42 108,18 122,40" Fill="#FFF3E9D2" Stroke="#FF4A4036" StrokeThickness="3"/>

            <!-- 头 -->
            <Ellipse Canvas.Left="70" Canvas.Top="35" Width="60" Height="55"
                     Fill="#FFF3E9D2" Stroke="#FF4A4036" StrokeThickness="3"/>

            <!-- 眼睛 -->
            <Ellipse Canvas.Left="86" Canvas.Top="55" Width="8" Height="8" Fill="#FF4A4036"/>
            <Ellipse Canvas.Left="106" Canvas.Top="55" Width="8" Height="8" Fill="#FF4A4036"/>
            <!-- 腮红 -->
            <Ellipse Canvas.Left="80" Canvas.Top="65" Width="10" Height="6" Fill="#55E8836B"/>
            <Ellipse Canvas.Left="110" Canvas.Top="65" Width="10" Height="6" Fill="#55E8836B"/>

            <!-- 左爪：以肩部为支点旋转，平时抬起、按键时拍下 -->
            <Ellipse x:Name="LeftPaw" Canvas.Left="48" Canvas.Top="95" Width="34" Height="26"
                     Fill="#FFEFE0C4" Stroke="#FF4A4036" StrokeThickness="3"
                     RenderTransformOrigin="0.85,0.1">
                <Ellipse.RenderTransform>
                    <RotateTransform x:Name="LeftPawRotate" Angle="-32"/>
                </Ellipse.RenderTransform>
            </Ellipse>

            <!-- 右爪 -->
            <Ellipse x:Name="RightPaw" Canvas.Left="118" Canvas.Top="95" Width="34" Height="26"
                     Fill="#FFEFE0C4" Stroke="#FF4A4036" StrokeThickness="3"
                     RenderTransformOrigin="0.15,0.1">
                <Ellipse.RenderTransform>
                    <RotateTransform x:Name="RightPawRotate" Angle="32"/>
                </Ellipse.RenderTransform>
            </Ellipse>

        </Canvas>
    </Viewbox>
</Window>
