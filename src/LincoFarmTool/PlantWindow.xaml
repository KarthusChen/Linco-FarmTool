<Window x:Class="LincoFarmTool.PlantWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="种菜"
        Width="384" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize"
        FontFamily="Microsoft YaHei UI"
        TextOptions.TextFormattingMode="Ideal">

    <Border CornerRadius="18" Margin="12" Background="{StaticResource CardBg}"
            BorderBrush="{StaticResource Line}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="22" ShadowDepth="3" Opacity="0.28" Color="#7A6A4A"/>
        </Border.Effect>

        <StackPanel Margin="22,18,22,22">

            <!-- 标题栏 -->
            <Grid x:Name="Header" Background="Transparent" Margin="0,0,0,6">
                <TextBlock Text="🌱 种菜 · 一键设肝帝闹钟" FontSize="16" FontWeight="Bold" Foreground="{StaticResource Ink}"/>
                <Button x:Name="CloseBtn" Content="✕" Width="28" Height="28" HorizontalAlignment="Right"
                        Style="{StaticResource GhostButton}" FontSize="12" Click="OnCancel"/>
            </Grid>

            <!-- 选作物 -->
            <TextBlock Text="选择作物（选了自动带出周期，可不选）" Foreground="{StaticResource Muted}" FontSize="12" Margin="0,8,0,4"/>
            <ComboBox x:Name="CropCombo" Style="{StaticResource ModernCombo}" SelectionChanged="OnCropSelected"/>

            <!-- 作物名 -->
            <TextBlock Text="作物名" Foreground="{StaticResource Muted}" FontSize="12" Margin="0,14,0,4"/>
            <TextBox x:Name="NameBox" Style="{StaticResource RoundTextBox}"/>

            <!-- 自然周期 -->
            <TextBlock Text="自然周期" Foreground="{StaticResource Muted}" FontSize="12" Margin="0,14,0,4"/>
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="Cycle1"  Content="1小时"  GroupName="Cycle" Style="{StaticResource Pill}"/>
                <RadioButton x:Name="Cycle8"  Content="8小时"  GroupName="Cycle" Style="{StaticResource Pill}"/>
                <RadioButton x:Name="Cycle16" Content="16小时" GroupName="Cycle" IsChecked="True" Style="{StaticResource Pill}"/>
                <RadioButton x:Name="Cycle32" Content="32小时" GroupName="Cycle" Style="{StaticResource Pill}"/>
            </StackPanel>

            <!-- 种植时间 -->
            <TextBlock Text="种植时间（默认现在，也可选之前种下的时间）" Foreground="{StaticResource Muted}" FontSize="12" Margin="0,14,0,4"/>
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="DayBefore"    Content="前天" GroupName="Day" Style="{StaticResource Pill}"/>
                <RadioButton x:Name="DayYesterday" Content="昨天" GroupName="Day" Style="{StaticResource Pill}"/>
                <RadioButton x:Name="DayToday"     Content="今天" GroupName="Day" IsChecked="True" Style="{StaticResource Pill}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,10,0,0" VerticalAlignment="Center">
                <TextBox x:Name="HourBox" Width="56" Text="00" TextAlignment="Center" Style="{StaticResource RoundTextBox}"/>
                <TextBlock Text=":" Margin="7,0,7,0" VerticalAlignment="Center" FontWeight="Bold" Foreground="{StaticResource Ink}"/>
                <TextBox x:Name="MinuteBox" Width="56" Text="00" TextAlignment="Center" Style="{StaticResource RoundTextBox}"/>
                <Button Content="此刻" Width="60" Margin="12,0,0,0" Style="{StaticResource GhostButton}" Click="OnNow"/>
            </StackPanel>

            <!-- 预览 -->
            <Border Background="#FFFFF4E2" BorderBrush="#FFF3DCB0" BorderThickness="1"
                    CornerRadius="12" Padding="14,12" Margin="0,16,0,0">
                <StackPanel>
                    <TextBlock x:Name="PreviewTitle" Text="肝帝模式预览" FontWeight="Bold" Foreground="#FFC0791A"/>
                    <TextBlock x:Name="PreviewBody" Margin="0,6,0,0" FontSize="12.5" LineHeight="20"
                               Foreground="#FF8A6428" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                <Button Content="取消" Width="76" Style="{StaticResource GhostButton}" Click="OnCancel"/>
                <Button Content="🌾 一键设肝帝闹钟" Width="164" Margin="10,0,0,0"
                        Style="{StaticResource AccentButton}" Click="OnOk" IsDefault="True"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
