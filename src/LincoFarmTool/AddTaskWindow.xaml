<Window x:Class="LincoFarmTool.AddTaskWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="添加收菜闹钟"
        Width="320" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FFFCFAF3">
    <StackPanel Margin="18">

        <TextBlock Text="任务名（如：1号地 浇水）" FontWeight="Bold"/>
        <TextBox x:Name="NameBox" Margin="0,4,0,0" Padding="4" FontSize="14"/>

        <TextBlock Text="提醒方式" FontWeight="Bold" Margin="0,14,0,0"/>
        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
            <RadioButton x:Name="ModeCountdown" Content="倒计时" IsChecked="True"
                         GroupName="Mode" Checked="OnModeChanged"/>
            <RadioButton x:Name="ModeAbsolute" Content="指定时间"
                         GroupName="Mode" Margin="16,0,0,0" Checked="OnModeChanged"/>
        </StackPanel>

        <!-- 倒计时输入 -->
        <StackPanel x:Name="CountdownPanel" Orientation="Horizontal" Margin="0,10,0,0" VerticalAlignment="Center">
            <TextBox x:Name="HoursBox" Width="48" Text="0" Padding="4" TextAlignment="Center"/>
            <TextBlock Text="小时" Margin="6,0,0,0" VerticalAlignment="Center"/>
            <TextBox x:Name="MinutesBox" Width="48" Text="0" Padding="4" TextAlignment="Center" Margin="12,0,0,0"/>
            <TextBlock Text="分钟后" Margin="6,0,0,0" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- 指定时间输入 -->
        <StackPanel x:Name="AbsolutePanel" Margin="0,10,0,0" Visibility="Collapsed">
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="DayToday" Content="今天" IsChecked="True" GroupName="Day"/>
                <RadioButton x:Name="DayTomorrow" Content="明天" Margin="16,0,0,0" GroupName="Day"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,8,0,0" VerticalAlignment="Center">
                <TextBox x:Name="HourBox" Width="48" Text="13" Padding="4" TextAlignment="Center"/>
                <TextBlock Text=":" Margin="6,0,6,0" VerticalAlignment="Center" FontWeight="Bold"/>
                <TextBox x:Name="MinuteBox" Width="48" Text="00" Padding="4" TextAlignment="Center"/>
                <TextBlock Text="（24小时制）" Margin="8,0,0,0" VerticalAlignment="Center" Foreground="Gray"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Content="取消" Width="66" Height="30" Click="OnCancel" IsCancel="True"/>
            <Button Content="确定" Width="66" Height="30" Margin="10,0,0,0" Click="OnOk" IsDefault="True"/>
        </StackPanel>
    </StackPanel>
</Window>
